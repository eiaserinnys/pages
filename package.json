{
  "name": "pages",
  "version": "1.0.0",
  "description": "Lightweight HTML report hosting service",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "worker:check": "node --check src/worker.mjs",
    "worker:dry-run": "npx --yes wrangler@4.86.0 deploy --dry-run",
    "worker:migrate:d1": "npx --yes wrangler@4.86.0 d1 migrations apply pages --remote",
    "worker:migrate:data": "python3 scripts/migrate_to_cloudflare.py",
    "worker:set-secrets": "python3 scripts/set_worker_secrets.py",
    "test": "node --test"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.1",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-session": "^1.17.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "uuid": "^11.1.1"
  },
  "allowScripts": {
    "better-sqlite3@12.10.1": true
  }
}
